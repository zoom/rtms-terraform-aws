# Development-shaped environment variables for local-only runs of the worker.
#
# Copy to `.env.development` and fill in. Both files are gitignored.
#
# If both `.env` and `.env.development` exist locally, `.env.development`
# loads SECOND and overrides — so dev devs never accidentally pick up prod
# credentials checked into `.env`.
#
# Use this for ngrok-tunnelled local testing against a sandbox Zoom account.

# --- Zoom RTMS app credentials (sandbox app, not the prod one) ---
ZM_RTMS_CLIENT=your_sandbox_client_id
ZM_RTMS_SECRET=your_sandbox_client_secret
ZM_RTMS_WEBHOOK_SECRET=your_sandbox_webhook_secret

# --- HTTP server ---
ZM_RTMS_PORT=8080

# --- SDK-internal logging (development: human-readable) ---
ZM_RTMS_LOG_FORMAT=progressive
ZM_RTMS_LOG_LEVEL=debug
ZM_RTMS_LOG_ENABLED=true

# --- Transcript storage ---
# Default for local dev: write chunks to ./transcripts/ on disk — no AWS
# credentials needed, easy to inspect from your terminal.
TRANSCRIPT_BACKEND=local
LOCAL_TRANSCRIPT_DIR=./transcripts

# (Only used if you flip TRANSCRIPT_BACKEND=s3 against a sandbox bucket.
# Run with AWS_PROFILE=sandbox so you don't write to a production bucket.)
# TRANSCRIPT_BUCKET=my-sandbox-rtms-transcripts
AWS_REGION=us-east-1

# --- Worker tuning ---
EVENTLOOP_THREADS=1
CALLBACK_EXECUTOR_WORKERS=4
TRANSCRIPT_FLUSH_INTERVAL=30

# --- Reconnection tuning (faster for testing) ---
RECONNECT_MAX_ATTEMPTS=3
RECONNECT_BACKOFF_BASE_SEC=2
RECONNECT_BACKOFF_CAP_SEC=10

# --- Application logging ---
LOG_LEVEL=DEBUG
