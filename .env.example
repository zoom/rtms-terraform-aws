# Environment variables for the RTMS worker.
#
# Copy to `.env` and fill in your credentials. Single source of truth — the
# same file shape is used for local dev and for documenting what Fargate
# expects from Secrets Manager. Lines marked `# DEV: <value>` show the
# development-friendly override (easier-to-read logs, smaller pools, faster
# reconnect). Flip them when running locally; leave production-shape for
# CloudWatch-bound deployments.
#
# **In deployed Fargate tasks no .env file exists** — env vars come from
# AWS Secrets Manager via the ECS task definition's `secrets` block.
# `.env` is gitignored. NEVER commit real credentials.

# --- Zoom RTMS app credentials (Marketplace > your RTMS app) ---
# Used only for the RTMS join handshake — the worker does NOT call the Zoom
# REST API, so no Server-to-Server OAuth account ID is required.
ZM_RTMS_CLIENT=your_rtms_client_id_here
ZM_RTMS_SECRET=your_rtms_client_secret_here

# --- Webhook signing token (Marketplace > Event Subscriptions > Secret Token) ---
ZM_RTMS_WEBHOOK_SECRET=your_webhook_secret_token_here

# --- HTTP server (the SDK's built-in webhook endpoint) ---
ZM_RTMS_PORT=8080

# --- Zoom host (Commercial Zoom or Zoom for Government) ---
# Commercial: https://zoom.us       (default)
# ZfG:        https://zoomgov.com
# ZM_RTMS_HOST=https://zoom.us

# --- SDK-internal logging ---
# Production: json + info → easy to parse in CloudWatch Logs Insights.
# Local dev:  progressive + debug → human-readable, full trace.
ZM_RTMS_LOG_FORMAT=json      # DEV: progressive
ZM_RTMS_LOG_LEVEL=info       # DEV: debug
ZM_RTMS_LOG_ENABLED=true

# --- Transcript storage ---
# s3    → PUT each chunk to TRANSCRIPT_BUCKET (production / Fargate)
# local → write each chunk under LOCAL_TRANSCRIPT_DIR on disk (local dev)
TRANSCRIPT_BACKEND=s3        # DEV: local
TRANSCRIPT_BUCKET=rtms-demo-transcripts-abcd1234
LOCAL_TRANSCRIPT_DIR=./transcripts

# --- AWS region (used when TRANSCRIPT_BACKEND=s3) ---
AWS_REGION=us-east-1

# --- Worker tuning ---
EVENTLOOP_THREADS=2          # DEV: 1
CALLBACK_EXECUTOR_WORKERS=16 # DEV: 4
TRANSCRIPT_FLUSH_INTERVAL=30

# --- Reconnection tuning ---
# Matches the curve in zoom/rtms-samples/rtms_api/reconnection_and_chaos_mode_js
RECONNECT_MAX_ATTEMPTS=5     # DEV: 3
RECONNECT_BACKOFF_BASE_SEC=3 # DEV: 2
RECONNECT_BACKOFF_CAP_SEC=30 # DEV: 10

# --- Application logging (separate from SDK logging above) ---
LOG_LEVEL=INFO               # DEV: DEBUG
