# Production-shaped environment variables for the RTMS worker.
#
# This file is the template for `.env` — the file the worker reads on local
# startup. **In deployed Fargate tasks no .env file exists** — env vars come
# from AWS Secrets Manager via the ECS task definition's `secrets` block.
#
# For local development, you usually want `.env.development.example` instead
# (progressive logs, easier-to-read formats).
#
# Copy to `.env` and fill in. `.env` is gitignored. NEVER commit real credentials.

# --- Zoom RTMS app credentials (Marketplace > your RTMS app) ---
# Used only for the RTMS join handshake — the worker does NOT call the Zoom
# REST API, so no Server-to-Server OAuth account ID is required.
ZM_RTMS_CLIENT=your_rtms_client_id_here
ZM_RTMS_SECRET=your_rtms_client_secret_here

# --- Webhook signing token (Marketplace > Event Subscriptions > Secret Token) ---
ZM_RTMS_WEBHOOK_SECRET=your_webhook_secret_token_here

# --- HTTP server (the SDK's built-in webhook endpoint) ---
ZM_RTMS_PORT=8080

# --- Zoom host (Commercial Zoom or Zoom for Government) ---
# Commercial: https://zoom.us       (default)
# ZfG:        https://zoomgov.com
# ZM_RTMS_HOST=https://zoom.us

# --- SDK-internal logging (production: machine-readable JSON for CloudWatch) ---
ZM_RTMS_LOG_FORMAT=json
ZM_RTMS_LOG_LEVEL=info
ZM_RTMS_LOG_ENABLED=true

# --- Transcript storage ---
# s3    → PUT each chunk to TRANSCRIPT_BUCKET (production / Fargate)
# local → write each chunk under LOCAL_TRANSCRIPT_DIR on disk (local dev)
TRANSCRIPT_BACKEND=s3
TRANSCRIPT_BUCKET=rtms-demo-transcripts-abcd1234
LOCAL_TRANSCRIPT_DIR=./transcripts

# --- AWS region (used when TRANSCRIPT_BACKEND=s3) ---
AWS_REGION=us-east-1

# --- Worker tuning ---
EVENTLOOP_THREADS=2
CALLBACK_EXECUTOR_WORKERS=16
TRANSCRIPT_FLUSH_INTERVAL=30

# --- Reconnection tuning ---
# Matches the curve in zoom/rtms-samples/rtms_api/reconnection_and_chaos_mode_js
RECONNECT_MAX_ATTEMPTS=5
RECONNECT_BACKOFF_BASE_SEC=3
RECONNECT_BACKOFF_CAP_SEC=30

# --- Application logging (separate from SDK logging above) ---
LOG_LEVEL=INFO
